# Wizard AI Agent System Configuration

# App environment details
APP_NAME="Wizard AI Agent"
ENV="dev" # dev, prod, test
SYSTEM_PROFILE="laptop" # laptop, server, HPC

# Model Selection Config
MODEL_TYPE="ollama"
MODEL_NAME="deepseek-r1:1.5b"
WORKER_MODEL_NAME="qwen2.5-coder:1.5b" # Change to "qwen-speculative" if running speculative decoding setup
VISION_MODEL_NAME="llava:7b"
OLLAMA_BASE_URL="http://host.docker.internal:11434"

# Sandbox Network Isolation
# Set to True to block sandbox container internet access for maximum security
# Set to False to allow container to run pip installs for missing packages dynamically
SANDBOX_NETWORK_DISABLED=False

# Global Model Parameters
MAX_TOKENS=4096
TEMPERATURE=0.0
LLM_NUM_CTX=4096
LLM_NUM_THREAD=8
